qualitylensfocustech.duckdns.org {
    # Serve static frontend files
    root * /srv/build

    # API endpoints (must be proxied to backend:8000)
    @api {
        path /token /token/
        path /openapi.json
        path /health
        path /my-analysis-tasks
        path /bulk-analyze
        path /users*
        path /analyze*
        path /bulk-status*
        path /bulk-cancel*
        path /bulk-job*
        path /bulk-download*
        path /bulk-excel-data*
        path /results*
        path /dashboard*
        path /docs*
    }

    handle @api {
        reverse_proxy backend:8000
    }

    # Fallback to frontend SPA
    handle {
        try_files {path} /index.html
        file_server
    }
}
